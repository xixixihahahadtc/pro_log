# ============================================
# 环境变量模板
# 复制此文件为 .env 并填入真实值
# .env 文件不会被 Git 追踪（已在 .gitignore 中）
# ============================================

# 数据库
DB_URL=jdbc:mysql://localhost:3306/blog_pro?serverTimezone=GMT%2B8&useUnicode=true&characterEncoding=utf-8&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=your-db-password-here

# JWT 密钥（生产环境务必更换！至少 32 字符）
JWT_SECRET=your-secret-key-at-least-32-characters-change-me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# 初始管理员账号（首次启动时自动创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please
